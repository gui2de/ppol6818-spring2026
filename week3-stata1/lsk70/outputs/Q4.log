. 
. *Run loop through all sheets and import
. forvalues i = 1/135 {
  2. 
.     import excel "$xls21", sheet("Table `i'") firstrow clear allstring
  3.     di as txt "Now processing sheet: `i'"        // update on load progress
  4.         
. ****************************************************
.     * Post-fix: OCR pattern inside sheet
.     *  - Row n has "OVERALL" and the true label/id
.     *  - Row n+1 has the actual data but shifted left by 1
.     *  - Shift row t+1 right, move label down, then drop row t
. ****************************************************
. 
.     ds TABLE21PAKISTANICITIZEN1, not
  5.     local cols `r(varlist)'
  6. 
.     gen byte __overall  = regexm(upper(TABLE21PAKISTANICITIZEN1), "OVERALL")
  7.     gen byte __shiftrow = (__overall[_n-1] == 1)
  8. 
.     *Move the label/id from the OVERALL row into the shifted row
.     replace TABLE21PAKISTANICITIZEN1 = TABLE21PAKISTANICITIZEN1[_n-1] if __shiftrow
  9. 
.     *Shift all other columns one place right on the shifted row
.     local n : word count `cols'
 10.     forvalues j = `n'(-1)2 {
 11.         local cur  : word `j' of `cols'
 12.         local prev : word `=`j'-1' of `cols'
 13.         replace `cur' = `prev' if __shiftrow
 14.     }
 15. 
.     *First numeric column becomes blank after shift
.     local first : word 1 of `cols'
 16.     replace `first' = "" if __shiftrow
 17. 
.     *Drop the OVERALL row now that its label was moved down
.     drop if __overall
 18. 
.     drop __overall __shiftrow
 19. 
. ****************************************************
.         
.         *Keep rows containing "18 AND"
.         keep if regexm(upper(TABLE21PAKISTANICITIZEN1), "18 AND")       // scans for rows with "18 AN
> D"
 20. 
.         count
 21.         if r(N)==0 {
 22.                 di as error "WARNING: no '18 AND' row in Table `i'"             // flags sheets wi
> thout identified "18 AND" row without breaking code
 23.                 continue
 24.         }
 25. 
.         *Among candidate rows, keep the row with the most numeric-looking cells
.         *To avoid accidentally keeping the OVERALL/header row
.         ds TABLE21PAKISTANICITIZEN1, not
 26.         local candvars `r(varlist)'
 27. 
.         gen nnums = 0
 28.         foreach x of local candvars {
 29.                 gen __tmp = trim(`x')
 30.                 replace __tmp = subinstr(__tmp, ",", "", .)
 31.                 replace nnums = nnums + regexm(__tmp, "^[0-9]+$") if !missing(__tmp)
 32.                 drop __tmp
 33.         }
 34. 
.         gsort -nnums
 35.         keep in 1               // keep the "18 AND" row with most numeric values
 36.         drop nnums
 37. 
.     rename TABLE21PAKISTANICITIZEN1 table21
 38. 
.     *Create id to append to table21
.     gen district_id = `i'    // labeling the districts by sheet n
 39. 
.     *Extract columns 2–13
. 
.     *Create target numeric variables
.     forvalues k = 2/13 {
 40.         gen double v`k' = .      // creating variables v2, v3, ... within loop
 41.     }
 42. 
. *Collect all numeric chunks from the kept row and fill v2-v13
. ds table21 district_id v2-v13, not
 43. local datavars `r(varlist)'
 44. 
. local nums ""
 45. 
. foreach x of local datavars {
 46.     local s = trim(`x'[1])
 47.     local s = subinstr("`s'", ",", "", .)
 48.     local s = subinstr("`s'", "%", "", .)
 49. 
.     while regexm("`s'", "([0-9]+)") {
 50.         local chunk = regexs(1)
 51.         local nums "`nums' `chunk'"
 52.         local s = regexr("`s'", "[0-9]+", " ")
 53.     }
 54. }
 55. 
. *Clear and fill v2-v13
. forvalues k = 2/13 {
 56.     replace v`k' = .
 57. }
 58. 
. local found = 0
 59. foreach n of local nums {
 60.     local ++found
 61.     if `found' > 12 continue, break
 62.     local idx = `found' + 1
 63.     replace v`idx' = real("`n'") in 1
 64. }
 65. 
. *Count explicit missing markers in the kept row (dash/dot/etc.)
. local nmiss = 0
 66. foreach x of local datavars {
 67.     local s2 = upper(trim(`x'[1]))
 68.     if inlist("`s2'", ".", "-", "—", "–", "NA", "N/A") local ++nmiss
 69. }
 70. 
. *Only flag as OCR problem if we cannot account for 12 slots
. if (`found' + `nmiss' < 12) {
 71.     di as error "Table `i': `found' numeric + `nmiss' explicit-missing = " ///
>         (`found'+`nmiss') " (<12). Likely OCR/alignment problem."
 72. }
 73. else if (`found' != 12) {
 74.     di as txt "Table `i': `found' numeric values; `nmiss' explicit missing markers (OK if missing 
> categories)."
 75. }
 76. 
. if (`found' != 12) di as error "Table `i' extracted `found' numeric values (expected 12)"
 77. 
. ****************************************************
. 
.     keep district_id table21 v2-v13
 78. 
.     save `one', replace        // saves single row of data in memory to 'one'
 79.     use `table21', clear
 80.     append using `one'         // adds the saved 'one' row onto master table21
 81.     save `table21', replace
 82. }
